						{
							"name": "sendPayment - BPW",
							"event": [
								{
									"listen": "prerequest",
									"script": {
										"exec": [
											"const prefix = \"REQ\";\r",
											"const timestamp = Date.now(); // current time in ms\r",
											"const random = Math.floor(Math.random() * 1000);\r",
											" \r",
											"const reqId = prefix + timestamp + random;\r",
											" \r",
											"pm.environment.set(\"reqId\", reqId);"
										],
										"type": "text/javascript",
										"packages": {}
									}
								},
								{
									"listen": "test",
									"script": {
										"exec": [
											"let response = pm.response.json();\r",
											" \r",
											"// Extract values\r",
											"let txnId = response.txnId;\r",
											"let customerId = response.customerId;\r",
											"let requestId = response.reqId;\r",
											" \r",
											"// Save to environment variables\r",
											"pm.environment.set(\"txnId\", txnId);\r",
											"pm.environment.set(\"customerId\", customerId);\r",
											"pm.environment.set(\"reqId\", requestId)\r",
											" \r",
											"// Optional: print in console for debugging\r",
											"console.log(\"Transaction ID:\", txnId);\r",
											"console.log(\"Customer ID:\", customerId);"
										],
										"type": "text/javascript",
										"packages": {}
									}
								}
							],
